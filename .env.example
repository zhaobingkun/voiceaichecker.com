PORT=8787
APP_BASE_URL=http://localhost:8787

# Keep this key on the server. Never expose it in public/app.js or HTML.
MODULATE_API_KEY=

# Batch synthetic voice detection endpoint.
MODULATE_API_URL=https://modulate-developer-apis.com/api/velma-2-synthetic-voice-detection-batch

MAX_FILE_MB=10
MAX_ANALYZE_SECONDS=30
DAILY_IP_LIMIT=3
AUTH_DAILY_LIMIT=10
SESSION_SECRET=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional Google login. Create an OAuth 2.0 Web Client in Google Cloud Console.
# Authorized redirect URI:
# http://localhost:8787/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
